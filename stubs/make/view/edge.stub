{{{
  exports({
    to: app.makePath('resources/views', entity.path, entity.name.toLowerCase() + '.edge')
  })
}}}
<!DOCTYPE html>
<html>
<head>
  <title>{{ entity.className }}</title>
</head>
<body>
  <h1>{{ entity.className }} View</h1>
  <p>This is the {{ entity.name.toLowerCase() }} view generated by Blueprint.</p>
</body>
</html>
